# qwik_write_safety.rules
# Technology: qwik | Capability: write

rule qwik-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_qwik_PATTERN"
  MESSAGE "Blocked an unsafe pattern in qwik. Use the recommended best practices for 2025/2026."
}

rule qwik-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_qwik_API"
  MESSAGE "You are using an outdated API for qwik. Please upgrade to the newer API."
}
